      "inputs": [
        {"channel": "harmocap.slot_0_symmetry", "include_when": {"channel": "harmocap.slot_0_focused", "op": "eq", "value": 1.0}},
        {"channel": "harmocap.slot_1_symmetry", "include_when": {"channel": "harmocap.slot_1_focused", "op": "eq", "value": 1.0}}
      ],
      "operator": "mean",
      "cadence": {"mode": "on_input", "max_rate_hz": 60.0},
      "validity": {"min_valid_count": 1, "min_observed_count": 1, "max_age_ms": 250.0, "include_held": false, "held_max_ms": 0.0, "confidence": "minimum"}
