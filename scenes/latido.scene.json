  "routes": [
    {
      "route_id": "expansion-to-h2-phase",
      "route_version": 1,
      "enabled": true,
      "label": "Body openness -> harmonic 2 phase (largest-scale morph)",
      "inputs": [{"channel": "focused_expansion.value"}],
      "transforms": [
        {"type": "scale_range", "in": [0.0, 1.0], "out": [-30.0, 30.0], "clamp": true},
        {"type": "phase_accumulator", "wrap_deg": 360.0, "max_dt_ms": 100.0}
      ],
      "destination": {"instrument_id": "shaper", "capability": "harmonic_phase", "bindings": {"N": 2}, "argument": "phase_degrees"},
      "validity": {"held": "reject", "min_confidence": 0.8, "invalid": "suppress"}
    },
    {
      "route_id": "verticality-to-h3-phase",
      "route_version": 1,
      "enabled": true,
      "label": "Posture up/down -> harmonic 3 phase",
      "inputs": [{"channel": "focused_verticality.value"}],
      "transforms": [
        {"type": "scale_range", "in": [-1.0, 1.0], "out": [-28.0, 28.0], "clamp": true},
        {"type": "phase_accumulator", "wrap_deg": 360.0, "max_dt_ms": 100.0}
      ],
      "destination": {"instrument_id": "shaper", "capability": "harmonic_phase", "bindings": {"N": 3}, "argument": "phase_degrees"},
      "validity": {"held": "reject", "min_confidence": 0.8, "invalid": "suppress"}
    },
    {
      "route_id": "symmetry-to-h4-phase",
      "route_version": 1,
      "enabled": true,
      "label": "Body symmetry -> harmonic 4 phase",
      "inputs": [{"channel": "focused_symmetry.value"}],
      "transforms": [
        {"type": "scale_range", "in": [0.0, 1.0], "out": [-22.0, 22.0], "clamp": true},
        {"type": "phase_accumulator", "wrap_deg": 360.0, "max_dt_ms": 100.0}
      ],
      "destination": {"instrument_id": "shaper", "capability": "harmonic_phase", "bindings": {"N": 4}, "argument": "phase_degrees"},
      "validity": {"held": "reject", "min_confidence": 0.8, "invalid": "suppress"}
    },
    {
      "route_id": "elbow-to-h5-phase",
      "route_version": 1,
      "enabled": true,
      "label": "Right arm extension -> harmonic 5 phase (finest morph)",
      "inputs": [{"channel": "focused_elbow_r.value"}],
      "transforms": [
        {"type": "scale_range", "in": [0.0, 1.0], "out": [-24.0, 24.0], "clamp": true},
        {"type": "phase_accumulator", "wrap_deg": 360.0, "max_dt_ms": 100.0}
      ],
      "destination": {"instrument_id": "shaper", "capability": "harmonic_phase", "bindings": {"N": 5}, "argument": "phase_degrees"},
      "validity": {"held": "reject", "min_confidence": 0.8, "invalid": "suppress"}
    },
    {
      "route_id": "ecg-beat-to-master-pulse",
      "route_version": 1,
      "enabled": true,
      "label": "Heartbeat edge -> master gain flash (figure brightens per beat)",
      "inputs": [{"channel": "ecg.beat"}],
      "transforms": [
        {"type": "gate", "threshold": 0.5, "hysteresis": 0.1, "mode": "rising_edge", "closed": {"value": 0.8}}
      ],
      "destination": {"instrument_id": "shaper", "capability": "master_gain", "bindings": {}, "argument": "gain"},
      "validity": {"held": "reject", "min_confidence": 0.8, "invalid": "release"}
    }
  ],
  "transition": {"policy": "crossfade", "duration_ms": 300.0, "await_valid_ms": 500.0}
}
