{
  "scene_id": "latido",
  "scene_version": 1,
  "name": "Latido",
  "description": "Two-person laser-cymatics piece. The focused HarMoCAP dancer's postural features drive per-harmonic PHASE velocities on the Shaper (harmonics 2-5; harmonic 1 is the unrouted phase anchor) so the projected figure morphs; the ECG beat edge pulses Shaper master gain so the figure brightens on each heartbeat. Requires the phase_accumulator transform (feat/phase-accumulator-transform).",
  "tags": ["latido", "performance", "laser-cymatics"],
  "created_at_us": 0,
  "updated_at_us": 0,
  "aggregators": [
    {
      "aggregator_id": "focused-expansion",
      "aggregator_version": 1,
      "derived_source_id": "focused_expansion",
      "output_channel": "value",
      "inputs": [
        {"channel": "harmocap.slot_0_expansion", "include_when": {"channel": "harmocap.slot_0_focused", "op": "eq", "value": 1.0}},
        {"channel": "harmocap.slot_1_expansion", "include_when": {"channel": "harmocap.slot_1_focused", "op": "eq", "value": 1.0}}
      ],
      "operator": "mean",
      "cadence": {"mode": "on_input", "max_rate_hz": 60.0},
      "validity": {"min_valid_count": 1, "min_observed_count": 1, "max_age_ms": 250.0, "include_held": false, "held_max_ms": 0.0, "confidence": "minimum"}
    },
